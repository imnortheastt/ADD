# Python
__pycache__/
*.py[cod]

# Python packaging build artifacts (the PyPI add-method package)
# The bundled data (src/add_method/_bundled/) IS committed — it is generated by
# scripts/prepare_bundle.py and guarded by tooling/test_bundle_parity.py.
*.egg-info/
build/
dist/
.eggs/

# Node
node_modules/
*.tgz

# OS
.DS_Store

# Backups left by `add.py sync-guidelines` when it rewrites an existing file
*.bak

# Tooling / MCP workspace artifacts (not part of the product)
.serena/

# ADD runtime: keep state + tasks + survivor files, but not the bundled book copy
# (the book source already lives at the repo root / in add-method/docs)
.add/docs/
.add/tooling/__pycache__/
tmp/

# add-method/ is the PACKAGE SOURCE, never an ADD-managed project. A stray
# `init` there (e.g. during installer smoke tests) must never be committed.
add-method/.add/
add-method/.claude/
add-method/AGENTS.md
add-method/CLAUDE.md
